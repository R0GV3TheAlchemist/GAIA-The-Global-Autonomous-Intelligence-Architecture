# GAIA Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file.
#
# ADR-0011 SOVEREIGNTY PRINCIPLE:
#   Cloud LLM providers are OPTIONAL AUGMENTATION.
#   GAIA runs fully on local Ollama models by default.
#   GAIA_ALLOW_CLOUD=0 (default) — local only.
#   Set GAIA_ALLOW_CLOUD=1 to opt in to cloud augmentation.
#   Cloud keys are NEVER required. Cloud is NEVER in the fallback chain.

# ── Sovereignty Gate (ADR-0011) ───────────────────────────────────────────────
# Set to 1 to enable cloud LLM augmentation (Anthropic, OpenAI, Perplexity).
# Default: 0 (local-only — recommended for privacy and sovereignty).
# Even when enabled, cloud failure ALWAYS routes to local Ollama automatically.
GAIA_ALLOW_CLOUD=0

# ── Ollama — Local LLM (primary sovereignty tier) ───────────────────────
# Ollama API host — default assumes local install
OLLAMA_HOST=http://localhost:11434

# Legacy alias (kept for backwards compatibility; OLLAMA_HOST takes precedence)
OLLAMA_BASE_URL=http://localhost:11434

# Primary local model (ADR-0011 MEDIUM tier — recommended)
# qwen3.5:27b  → best quality/reasoning, requires ~16 GB VRAM
# gemma3:12b   → fast and balanced, requires ~8 GB VRAM (good default for most hardware)
# gemma3:1b    → ultra-light, CPU-capable, ~800 MB
OLLAMA_MODEL=qwen3.5:27b

# Lightweight fallback model (ADR-0011 LOW tier)
# Used automatically when primary is unavailable or for fast/low-complexity tasks.
# gemma3:12b   → recommended fallback
# phi3:mini    → ultra-light alternative
OLLAMA_FALLBACK_MODEL=gemma3:12b

# Legacy model alias — kept for backwards compatibility
GAIA_MODEL=qwen3.5:27b

# Set to 1 to explicitly force Ollama even when cloud keys are present
OLLAMA_ENABLED=1

# ── Cloud LLM backends (all optional — GAIA works fully without these) ─────
# Requires GAIA_ALLOW_CLOUD=1 to activate.
# Cloud providers are NEVER in the fallback chain.
# Cloud failure always routes to local Ollama automatically.

# Perplexity — web-grounded queries (sonar / sonar-pro / sonar-reasoning-pro)
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro

# OpenAI — optional cloud augmentation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic — optional cloud augmentation
# Note: access may be subject to export controls (see THREAT-001 in threat_model.md)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── Auth (core/auth.py) ──────────────────────────────────────────────────
# HS256 signing secret for JWT tokens.
# REQUIRED in production — if unset, an ephemeral key is generated on each
# restart (all existing tokens are invalidated on restart).
# Generate with: openssl rand -hex 32
GAIA_SECRET_KEY=

# Access token lifetime in minutes (default: 60)
GAIA_TOKEN_EXPIRE=60

# Admin registration key — provide this when calling POST /auth/token to
# receive a token with role="admin". Keep this secret.
# Generate with: openssl rand -hex 24
GAIA_ADMIN_KEY=

# ── Server ──────────────────────────────────────────────────────────────
GAIA_PORT=8008

# ── IBM Quantum (P6 Part 2 — optional) ────────────────────────────────
# Required only for quantum circuit execution on real IBM hardware.
# If not set, GAIA uses the local Qiskit Aer simulator automatically.
IBMQ_API_KEY=

# ── Post-Quantum Encryption (P6 Part 1) ─────────────────────────────
# Set to 1 to enable ML-KEM/ML-DSA encryption (requires liboqs-python).
# If liboqs is not installed, GAIA falls back to AES-256-GCM automatically.
GAIA_PQC_ENABLED=1
